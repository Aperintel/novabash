    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "0.36.4",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "0.28.1",
    "typescript": "5.6.3"
  }
}
