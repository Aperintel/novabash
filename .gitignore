# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
.next/
out/
*.tsbuildinfo

# env
.env
.env.*
!.env.example

# editors
.vscode/
.idea/
*.swp

# system
.DS_Store
Thumbs.db
desktop.ini

# logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# local data
data/waitlist.jsonl

# server probe artefacts
.dev-server.*

# personal action list and planning artefacts (not tracked)
OUTSTANDING.txt
BLOCKERS.md
DEPLOY.md
NovaBash_Build_Plan.txt
novabash_blueprint.html
launch/

# Planning notes and internal docs stay local: all .md and .txt are ignored
# by default. Public repo-health docs are added back explicitly below.
*.md
*.txt
!README.md
!CONTRIBUTING.md
!SECURITY.md
!CODE_OF_CONDUCT.md
!CONTRIBUTORS.md
!LICENSE
!packages/brand/BRAND.md
# Internal HTML artefacts (mocks, prototypes, infographics) also stay local.
*-infographic.html
*-mock.html
*-prototype.html
# Public repo-health files (override the broad *.md ignore above)
!SECURITY.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!README.md
!CONTRIBUTORS.md
!.github/**/*.md
