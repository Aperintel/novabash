{
  "name": "novabash",
  "version": "0.0.0",
  "private": true,
  "description": "NovaBash monorepo. Phase A BYOK developer infrastructure platform.",
  "scripts": {
    "dev": "pnpm --filter @novabash/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "typescript": "5.6.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
