# NovaBash web · single deploy unit on Vercel hobby
# Copy to .env.local and fill in once accounts exist.

# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (Supabase · Settings · Database · Connection
# Pooling · Transaction mode). Required by /api/v1/* routes that hit the
# vault, audit log, and key health.
DATABASE_URL=

# Vault master key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 32-byte base64 string. Migrate to AWS KMS at v1.0.
VAULT_MASTER_KEY=

# Admin token for /api/v1/admin/* endpoints (validation cron). Generate:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_TOKEN=

# ── OAuth providers ───────────────────────────────────────────────────
# Configured inside Supabase Auth · Providers. Listed here for reference.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Email ─────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Site URL (used for OAuth redirects) ───────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: Upstash Redis for distributed rate limiting ─────────────
# When unset, the Edge middleware no-ops and traffic is unrate-limited.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_SECONDS=60

# ── Optional: PostHog activation event ────────────────────────────────
# When unset, capture is no-op.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ── Optional: Stripe (set after business verification completes) ──────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=
