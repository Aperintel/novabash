# Cloudflare Pages headers. Applied to every response.
# The CSP confines scripts, styles, fonts, images, and network calls to the
# app's own origin, and blocks third-party code, plugins, and framing. Inline
# script is allowed because Next.js static export embeds hydration scripts and
# nonces require a server; the no-third-party and no-framing rules are the main
# protection for a client-side vault.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
