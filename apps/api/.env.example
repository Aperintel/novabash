# NovaBash API · Railway-side environment

# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/novabash

# Vault master key (envelope encryption). pgcrypto MVP, AWS KMS at week 15.
VAULT_MASTER_KEY=

# CORS allowlist (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://novabash.dev

# Rate limit
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
